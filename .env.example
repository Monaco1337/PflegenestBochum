# =============================================================
# PflegeNest OS - Environment Variables
# =============================================================
# Copy this file to `.env` (or `.env.local`) and fill in values.
# Do NOT commit `.env*` files with real secrets.
# =============================================================

# --- Database (Prisma) -------------------------------------------------------
# When unset, the system falls back to an in-memory repository with seeded
# demo data (DEMO_MODE). Suitable for local UI development and previews only.
# In production, set this to your Postgres/MySQL connection string.
# Example (Postgres): postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL=

# --- Authentication ----------------------------------------------------------
# Used to sign session cookies. Generate via: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- AI Providers (optional, not required for default heuristics) ------------
# When set, the AI Command Center upgrades from rule-based heuristics to real LLM calls.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Object Storage (optional, falls back to local FS in dev) ----------------
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Email (optional) --------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=info@pflegenest-bochum.de

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=PflegeNest OS
NEXT_PUBLIC_SITE_URL=https://www.pflegenest-bochum.de
NEXT_PUBLIC_COMPANY_NAME=PflegeNest Bochum
NEXT_PUBLIC_COMPANY_PHONE=02327 / 9911907
NEXT_PUBLIC_COMPANY_EMAIL=info@pflegenest-bochum.de
NEXT_PUBLIC_COMPANY_ADDRESS=Ruhrstraße 2, 44869 Bochum

# --- Feature Flags -----------------------------------------------------------
# Toggle the demo data layer explicitly. When DATABASE_URL is unset this is auto-on.
DEMO_MODE=true
